@model DungMoHinh.Models.TaiNguyen3D

@{
    ViewData["Title"] = "Xóa tài nguyên 3D";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Quản lý thư viện</span>
        <h1>Xóa tài nguyên 3D</h1>
        <p>Tài nguyên sẽ được khóa để không còn gắn mới vào nhân vật, các nhân vật cũ vẫn giữ được dữ liệu.</p>
    </div>
</div>

<section class="panel danger-state">
    <h2 class="panel-title">@Model.Name</h2>
    <p class="panel-subtitle">Bạn có chắc muốn khóa tài nguyên này không?</p>
    <dl class="detail-list mt-3">
        <dt>Loại</dt>
        <dd>@Model.Type</dd>
        <dt>Điểm gắn</dt>
        <dd>@Model.DefaultDiemGan</dd>
        <dt>File</dt>
        <dd class="text-break">@Model.DuongDanFile</dd>
    </dl>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="toolbar mt-4">
        @Html.AntiForgeryToken()
        <button class="btn btn-outline-danger" type="submit">Xóa tài nguyên</button>
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Hủy</a>
    </form>
</section>
