@model IEnumerable<DungMoHinh.Models.TaiNguyen3D>

@{
    ViewData["Title"] = "Tai nguyen";
}

<h1>Tai nguyen</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Ten</th>
            <th>Loai</th>
            <th>Diem gan</th>
            <th>Dang hoat dong</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Type</td>
            <td>@item.DefaultDiemGan</td>
            <td>@item.IsActive</td>
            <td class="text-end"><a asp-action="Details" asp-route-id="@item.Id">Chi tiet</a></td>
        </tr>
    }
    </tbody>
</table>
