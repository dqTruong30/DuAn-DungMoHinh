@model IEnumerable<DungMoHinh.Models.TaiNguyen3D>

@{
    ViewData["Title"] = "Tài nguyên";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Thư viện 3D</span>
        <h1>Tài nguyên</h1>
        <p>Danh sách model, phụ kiện, vật liệu, texture và pose có thể gắn vào nhân vật.</p>
    </div>
</div>

<div class="table-wrap">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Tên</th>
                <th>Loại</th>
                <th>Điểm gắn</th>
                <th>Đang hoạt động</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Name</strong></td>
                <td><span class="status-pill">@item.Type</span></td>
                <td>@item.DefaultDiemGan</td>
                <td>@item.IsActive</td>
                <td class="text-end"><a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Chi tiết</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
