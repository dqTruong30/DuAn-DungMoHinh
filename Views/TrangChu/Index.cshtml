@{
    ViewData["Title"] = "Trang chủ";
}

<section class="hero-studio">
    <div class="hero-copy">
        <span class="eyebrow">3D Character Studio</span>
        <h1>Thiết kế nhân vật 3D theo ảnh, mẫu có sẵn và phong cách riêng.</h1>
        <p>
            Tạo nhân vật nam, nữ, chibi hoặc bình thường; tùy chỉnh tỷ lệ cơ thể,
            khuôn mặt, phụ kiện và tài nguyên 3D trong một không gian làm việc rõ ràng.
        </p>

        <div class="toolbar">
            <a class="btn btn-light" asp-controller="NhanVats" asp-action="Create">Tạo nhân vật</a>
            <a class="btn btn-outline-secondary" asp-controller="AnhTaiLens" asp-action="Index">Tải ảnh mẫu</a>
        </div>
    </div>

    <div class="preview-stage" aria-label="Minh họa không gian dựng nhân vật">
        <div class="stage-label">Live preview</div>
        <div class="avatar-preview"></div>
        <div class="preview-grid"></div>
    </div>
</section>

<section class="metric-grid mb-4">
    <div class="metric-card">
        <span>Kiểu nhân vật</span>
        <strong>4</strong>
        <small>Nam, nữ, chibi nam, chibi nữ</small>
    </div>
    <div class="metric-card">
        <span>Bộ chỉnh sửa</span>
        <strong>3</strong>
        <small>Cơ thể, khuôn mặt, phụ kiện</small>
    </div>
    <div class="metric-card">
        <span>Nguồn dữ liệu</span>
        <strong>2</strong>
        <small>Mẫu 3D và ảnh tải lên</small>
    </div>
    <div class="metric-card">
        <span>Đầu ra</span>
        <strong>GLB</strong>
        <small>Mở rộng thêm PNG, OBJ, FBX</small>
    </div>
</section>

<section class="workflow-grid">
    <article class="workflow-card">
        <span class="step">1</span>
        <h2>Chọn nền nhân vật</h2>
        <p>Bắt đầu từ mẫu nam, nữ, chibi hoặc tạo theo ảnh người dùng tải lên.</p>
    </article>
    <article class="workflow-card">
        <span class="step">2</span>
        <h2>Tùy chỉnh chi tiết</h2>
        <p>Điều chỉnh tỷ lệ cơ thể, màu sắc, khuôn mặt, phụ kiện và vị trí gắn.</p>
    </article>
    <article class="workflow-card">
        <span class="step">3</span>
        <h2>Lưu và xuất bản</h2>
        <p>Lưu cấu hình nhân vật, quản lý trong thư viện và chuẩn bị xuất file 3D.</p>
    </article>
</section>
