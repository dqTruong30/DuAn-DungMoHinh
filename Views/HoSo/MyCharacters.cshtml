@model IEnumerable<DungMoHinh.Models.NhanVat>

@{
    ViewData["Title"] = "Nhan vat cua toi";
}

<h1>Nhan vat cua toi</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Ten</th>
            <th>Loai</th>
            <th>Phong cach</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Kind.GetDisplayName()</td>
            <td>@item.Style.GetDisplayName()</td>
            <td class="text-end"><a asp-controller="NhanVats" asp-action="Editor" asp-route-id="@item.Id">Chinh sua</a></td>
        </tr>
    }
    </tbody>
</table>
