@model IEnumerable<DungMoHinh.Models.MauNhanVat>

@{
    ViewData["Title"] = "Mau nhan vat";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Preset khoi tao</span>
        <h1>Mau nhan vat</h1>
        <p>Cac mau nen giup nguoi dung tao nhanh nhan vat theo loai va phong cach mong muon.</p>
    </div>
</div>

<div class="table-wrap">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Ten</th>
                <th>Loai</th>
                <th>Phong cach</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Name</strong></td>
                <td><span class="status-pill">@item.Kind</span></td>
                <td>@item.Style</td>
                <td class="text-end"><a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Chi tiet</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
