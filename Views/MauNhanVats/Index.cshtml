@model IEnumerable<DungMoHinh.Models.MauNhanVat>

@{
    ViewData["Title"] = "Mẫu nhân vật";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Preset khởi tạo</span>
        <h1>Mẫu nhân vật</h1>
        <p>Các mẫu nền giúp người dùng tạo nhanh nhân vật theo loại và phong cách mong muốn.</p>
    </div>
</div>

<div class="table-wrap">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Tên</th>
                <th>Loại</th>
                <th>Phong cách</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Name</strong></td>
                <td><span class="status-pill">@item.Kind</span></td>
                <td>@item.Style</td>
                <td class="text-end"><a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Chi tiết</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
