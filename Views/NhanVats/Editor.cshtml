@model DungMoHinh.Models.NhanVat

@{
    ViewData["Title"] = "Trình chỉnh sửa nhân vật";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Trình dựng hình 3D</span>
        <h1>@Model.Name</h1>
        <p>Chỉnh tỷ lệ cơ thể, màu sắc, khuôn mặt và phụ kiện. Khu vực preview sẽ được gắn Three.js ở giai đoạn tiếp theo.</p>
    </div>
    <div class="toolbar">
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Chi tiết</a>
        <a class="btn btn-primary" asp-controller="TaiNguyens" asp-action="Index">Thêm tài nguyên</a>
    </div>
</div>

<div class="editor-grid">
    <section class="editor-stage" aria-label="Khu vực xem trước 3D">
        <div class="stage-label">Viewport 3D</div>
        <div class="avatar-preview"></div>
        <div class="preview-grid"></div>
        <div class="editor-tools">
            <div class="toolbar">
                <button class="btn btn-light btn-sm" type="button">Xoay</button>
                <button class="btn btn-light btn-sm" type="button">Phóng to</button>
                <button class="btn btn-light btn-sm" type="button">Ánh sáng</button>
            </div>
            <div class="toolbar">
                <button class="btn btn-outline-secondary btn-sm" type="button">Lưu bản nháp</button>
                <button class="btn btn-primary btn-sm" type="button">Xuất 3D</button>
            </div>
        </div>
    </section>

    <aside class="control-stack">
        <section class="panel">
            <div class="panel-header">
                <div>
                    <h2 class="panel-title">Cơ thể</h2>
                    <p class="panel-subtitle">Điều chỉnh các tỷ lệ chính của nhân vật.</p>
                </div>
                <span class="status-pill">@Model.Kind</span>
            </div>
            <div class="control-row">
                <label>Chiều cao</label>
                <strong>@Model.CauHinhCoThe?.OverallHeight</strong>
            </div>
            <div class="range-track mb-3"><span style="width: 72%;"></span></div>
            <div class="control-row">
                <label>Đầu</label>
                <strong>@Model.CauHinhCoThe?.DauScale</strong>
            </div>
            <div class="range-track mb-3"><span style="width: 58%;"></span></div>
            <div class="control-row">
                <label>Vai</label>
                <strong>@Model.CauHinhCoThe?.ShoulderWidth</strong>
            </div>
            <div class="range-track"><span style="width: 64%;"></span></div>
        </section>

        <section class="panel">
            <div class="panel-header">
                <div>
                    <h2 class="panel-title">Khuôn mặt</h2>
                    <p class="panel-subtitle">Màu sắc và đặc điểm nhận diện.</p>
                </div>
            </div>
            <div class="control-row">
                <label>Màu da</label>
                <strong>@Model.CauHinhKhuonMat?.MauDa</strong>
            </div>
            <div class="control-row">
                <label>Màu tóc</label>
                <strong>@Model.CauHinhKhuonMat?.MauToc</strong>
            </div>
            <div class="control-row">
                <label>Màu mắt</label>
                <strong>@Model.CauHinhKhuonMat?.MauMat</strong>
            </div>
        </section>

        <section class="panel">
            <div class="panel-header">
                <div>
                    <h2 class="panel-title">Tài nguyên đã chọn</h2>
                    <p class="panel-subtitle">Phụ kiện, trang phục và vật liệu gắn vào nhân vật.</p>
                </div>
            </div>
            @if (Model.TaiNguyenNhanVats.Any())
            {
                <div class="list-group list-group-flush">
                @foreach (var taiNguyen in Model.TaiNguyenNhanVats)
                {
                    <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                        <span>@taiNguyen.TaiNguyen3D.Name</span>
                        <span class="status-pill">@taiNguyen.TaiNguyen3D.Type</span>
                    </div>
                }
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Chưa gắn tài nguyên nào cho nhân vật này.</p>
            }
        </section>
    </aside>
</div>
