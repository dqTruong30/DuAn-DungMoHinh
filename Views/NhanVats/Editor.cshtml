@model DungMoHinh.Models.NhanVat

@{
    ViewData["Title"] = "Trinh chinh sua nhan vat";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@Model.Name</h1>
    <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Chi tiet</a>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="border rounded p-4 text-center bg-light" style="min-height: 420px;">
            <h2 class="h5">Xem truoc 3D</h2>
            <p class="text-muted">Khu vuc nay se dung de gan trinh xem 3D bang Three.js.</p>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="border rounded p-3 mb-3">
            <h2 class="h5">Co the</h2>
            <p>Chieu cao: @Model.CauHinhCoThe?.OverallHeight</p>
            <p>Dau: @Model.CauHinhCoThe?.DauScale</p>
            <p>Vai: @Model.CauHinhCoThe?.ShoulderWidth</p>
        </div>
        <div class="border rounded p-3 mb-3">
            <h2 class="h5">Khuon mat</h2>
            <p>Da: @Model.CauHinhKhuonMat?.MauDa</p>
            <p>Toc: @Model.CauHinhKhuonMat?.MauToc</p>
            <p>Mat: @Model.CauHinhKhuonMat?.MauMat</p>
        </div>
        <div class="border rounded p-3">
            <h2 class="h5">Tai nguyen da chon</h2>
            <ul class="mb-0">
            @foreach (var taiNguyen in Model.TaiNguyenNhanVats)
            {
                <li>@taiNguyen.TaiNguyen3D.Name</li>
            }
            </ul>
        </div>
    </div>
</div>
