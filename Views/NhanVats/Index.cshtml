@model IEnumerable<DungMoHinh.Models.NhanVat>

@{
    ViewData["Title"] = "Nhân vật";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Thư viện cá nhân</span>
        <h1>Nhân vật</h1>
        <p>Quản lý các nhân vật đã tạo, mở lại editor để tiếp tục tùy chỉnh hoặc xem chi tiết cấu hình.</p>
    </div>
    <div class="toolbar">
        <a class="btn btn-primary" asp-action="Create">Tạo mới</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h2>Chưa có nhân vật nào</h2>
        <p>Hãy tạo nhân vật đầu tiên để bắt đầu xây dựng thư viện thiết kế 3D của bạn.</p>
        <a class="btn btn-primary" asp-action="Create">Tạo nhân vật</a>
    </div>
}
else
{
    <div class="table-wrap">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Tên</th>
                    <th>Loại</th>
                    <th>Phong cách</th>
                    <th>Cập nhật</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <strong>@item.Name</strong>
                        <div class="text-muted small">@item.MoTa</div>
                    </td>
                    <td><span class="status-pill">@item.Kind</span></td>
                    <td>@item.Style</td>
                    <td>@(item.UpdatedAt ?? item.CreatedAt)</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-primary" asp-action="Editor" asp-route-id="@item.Id">Chỉnh sửa</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Chi tiết</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
