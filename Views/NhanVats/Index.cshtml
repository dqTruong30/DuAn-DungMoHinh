@model IEnumerable<DungMoHinh.Models.NhanVat>

@{
    ViewData["Title"] = "Nhan vat";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Nhan vat</h1>
    <a class="btn btn-primary" asp-action="Create">Tao moi</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Chua co nhan vat nao.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Ten</th>
                <th>Loai</th>
                <th>Phong cach</th>
                <th>Cap nhat</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Kind</td>
                <td>@item.Style</td>
                <td>@(item.UpdatedAt ?? item.CreatedAt)</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Editor" asp-route-id="@item.Id">Chinh sua</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Chi tiet</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
