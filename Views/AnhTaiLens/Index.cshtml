@model IEnumerable<DungMoHinh.Models.AnhTaiLen>
@using DungMoHinh.Models

@{
    ViewData["Title"] = "Ảnh tải lên";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Dữ liệu đầu vào</span>
        <h1>Ảnh tải lên</h1>
        <p>Tải ảnh nhân vật, ảnh phụ kiện hoặc texture để phục vụ bước phân tích và tạo gợi ý 3D.</p>
    </div>
</div>

<form asp-action="TaiLenImage" method="post" enctype="multipart/form-data" class="panel mb-4">
    <div class="panel-header">
        <div>
            <h2 class="panel-title">Tải ảnh mới</h2>
            <p class="panel-subtitle">Ảnh tải lên sẽ được lưu vào hệ thống để xử lý và gắn với nhân vật khi cần.</p>
        </div>
    </div>
    <div class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label" for="file">Tệp ảnh</label>
            <input class="form-control" type="file" name="file" id="file" />
        </div>
        <div class="col-md-4">
            <label class="form-label" for="anhTaiLenType">Loại ảnh</label>
            <select class="form-select" name="anhTaiLenType" id="anhTaiLenType" asp-items="Html.GetEnumSelectList<LoaiTaiLen>()"></select>
        </div>
        <div class="col-md-3">
            <button class="btn btn-primary w-100" type="submit">Tải lên</button>
        </div>
    </div>
</form>

<div class="table-wrap">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Tệp</th>
                <th>Loại</th>
                <th>Trạng thái</th>
                <th>Kích thước</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.TenFile</strong></td>
                <td>@item.LoaiTaiLen</td>
                <td><span class="status-pill">@item.Status</span></td>
                <td>@item.KichThuocFile</td>
            </tr>
        }
        </tbody>
    </table>
</div>
