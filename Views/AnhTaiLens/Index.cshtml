@model IEnumerable<DungMoHinh.Models.AnhTaiLen>
@using DungMoHinh.Models

@{
    ViewData["Title"] = "Anh tai len";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Du lieu dau vao</span>
        <h1>Anh tai len</h1>
        <p>Tai anh nhan vat, anh phu kien hoac texture de phuc vu buoc phan tich va tao goi y 3D.</p>
    </div>
</div>

<form asp-action="TaiLenImage" method="post" enctype="multipart/form-data" class="panel mb-4">
    <div class="panel-header">
        <div>
            <h2 class="panel-title">Tai anh moi</h2>
            <p class="panel-subtitle">Anh tai len se duoc luu vao he thong de xu ly va gan voi nhan vat khi can.</p>
        </div>
    </div>
    <div class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label" for="file">Tep anh</label>
            <input class="form-control" type="file" name="file" id="file" />
        </div>
        <div class="col-md-4">
            <label class="form-label" for="anhTaiLenType">Loai anh</label>
            <select class="form-select" name="anhTaiLenType" id="anhTaiLenType" asp-items="Html.GetEnumSelectList<LoaiTaiLen>()"></select>
        </div>
        <div class="col-md-3">
            <button class="btn btn-primary w-100" type="submit">Tai len</button>
        </div>
    </div>
</form>

<div class="table-wrap">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Tep</th>
                <th>Loai</th>
                <th>Trang thai</th>
                <th>Kich thuoc</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.TenFile</strong></td>
                <td>@item.LoaiTaiLen</td>
                <td><span class="status-pill">@item.Status</span></td>
                <td>@item.KichThuocFile</td>
            </tr>
        }
        </tbody>
    </table>
</div>
