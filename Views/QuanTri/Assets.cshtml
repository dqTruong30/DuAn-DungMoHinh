@model IEnumerable<DungMoHinh.Models.TaiNguyen3D>

@{
    ViewData["Title"] = "Quản trị tài nguyên";
}

<h1>Quản trị tài nguyên</h1>

<table class="table table-striped">
    <thead><tr><th>Tên</th><th>Loại</th><th>Đang hoạt động</th><th>Người dùng tạo</th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr><td>@item.Name</td><td>@item.Type</td><td>@item.IsActive</td><td>@item.IsUserGenerated</td></tr>
    }
    </tbody>
</table>
