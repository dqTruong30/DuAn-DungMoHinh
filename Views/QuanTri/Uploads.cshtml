@model IEnumerable<DungMoHinh.Models.AnhTaiLen>

@{
    ViewData["Title"] = "Quản trị ảnh tải lên";
}

<h1>Quản trị ảnh tải lên</h1>

<table class="table table-striped">
    <thead><tr><th>Tệp</th><th>Người dùng</th><th>Loại</th><th>Trạng thái</th><th>Ngày tạo</th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr><td>@item.TenFile</td><td>@item.UserId</td><td>@item.LoaiTaiLen</td><td>@item.Status</td><td>@item.CreatedAt</td></tr>
    }
    </tbody>
</table>
