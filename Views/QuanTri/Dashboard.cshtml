@model DungMoHinh.ViewModels.TongQuanQuanTri

@{
    ViewData["Title"] = "Bảng quản trị";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Quản trị hệ thống</span>
        <h1>Bảng quản trị</h1>
        <p>Theo dõi người dùng, nhân vật, mẫu thiết lập, tài nguyên 3D và lịch sử xuất file.</p>
    </div>
    <div class="toolbar">
        <a class="btn btn-primary" asp-controller="NhanVats" asp-action="Create">Tạo nhân vật</a>
    </div>
</div>

<section class="metric-grid mb-4">
    <div class="metric-card">
        <span>Người dùng</span>
        <strong>@Model.UserCount</strong>
        <small>Hồ sơ đang quản lý</small>
    </div>
    <div class="metric-card">
        <span>Nhân vật</span>
        <strong>@Model.NhanVatCount</strong>
        <small>Dự án đã tạo</small>
    </div>
    <div class="metric-card">
        <span>Mau</span>
        <strong>@Model.MauCount</strong>
        <small>Bộ khởi tạo nhanh</small>
    </div>
    <div class="metric-card">
        <span>Tài nguyên</span>
        <strong>@Model.TaiNguyenCount</strong>
        <small>Vật liệu và phụ kiện</small>
    </div>
    <div class="metric-card">
        <span>Ảnh tải lên</span>
        <strong>@Model.TaiLenCount</strong>
        <small>Ảnh mẫu và phụ kiện</small>
    </div>
    <div class="metric-card">
        <span>Lượt xuất</span>
        <strong>@Model.XuatCount</strong>
        <small>File đã tạo ra</small>
    </div>
</section>

<div class="workflow-grid">
    <a class="workflow-card" asp-action="Characters">
        <span class="step">NV</span>
        <h2>Nhân vật</h2>
        <p>Kiểm tra danh sách nhân vật và tình trạng cấu hình.</p>
    </a>
    <a class="workflow-card" asp-action="Assets">
        <span class="step">3D</span>
        <h2>Tài nguyên</h2>
        <p>Quản lý model, trang phục, phụ kiện, vật liệu và texture.</p>
    </a>
    <a class="workflow-card" asp-action="Uploads">
        <span class="step">AI</span>
        <h2>Ảnh tải lên</h2>
        <p>Theo dõi ảnh người dùng, ảnh phụ kiện và kết quả phân tích.</p>
    </a>
</div>
