@model IEnumerable<DungMoHinh.Models.NhanVat>

@{
    ViewData["Title"] = "Quản trị nhân vật";
}

<h1>Quản trị nhân vật</h1>

<table class="table table-striped">
    <thead><tr><th>Tên</th><th>Người dùng</th><th>Loại</th><th>Phong cách</th><th>Ngày tạo</th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr><td>@item.Name</td><td>@item.UserId</td><td>@item.Kind</td><td>@item.Style</td><td>@item.CreatedAt</td></tr>
    }
    </tbody>
</table>
