<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DungMoHinh</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DungMoHinh.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <div class="app-shell">
        <aside class="app-sidebar">
            <a class="app-brand" asp-controller="TrangChu" asp-action="Index" aria-label="Về trang chủ">
                <span class="brand-mark">DM</span>
                <span>
                    <strong>Dựng Mô Hình</strong>
                    <small>3D Character Studio</small>
                </span>
            </a>

            <nav class="sidebar-nav" aria-label="Điều hướng chính">
                <a asp-controller="TrangChu" asp-action="Index">Tổng quan</a>
                <a asp-controller="NhanVats" asp-action="Index">Nhân vật</a>
                <a asp-controller="MauNhanVats" asp-action="Index">Mẫu nhân vật</a>
                <a asp-controller="TaiNguyens" asp-action="Index">Thư viện 3D</a>
                <a asp-controller="AnhTaiLens" asp-action="Index">Ảnh tải lên</a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="QuanTri" asp-action="Dashboard">Quản trị</a>
                }
            </nav>

            <div class="sidebar-note">
                <span>Workspace</span>
                <strong>Thiết kế, lưu và xuất nhân vật 3D</strong>
            </div>
        </aside>

        <div class="app-main">
            <header class="topbar">
                <nav class="navbar navbar-expand-lg p-0">
                    <div class="container-fluid px-0">
                        <a class="mobile-brand" asp-controller="TrangChu" asp-action="Index">
                            <span class="brand-mark">DM</span>
                            <span>Dựng Mô Hình</span>
                        </a>
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation"
                                aria-expanded="false" aria-label="Mở điều hướng">
                    <span class="navbar-toggler-icon"></span>
                </button>
                        <div class="collapse navbar-collapse" id="mainNavigation">
                            <ul class="navbar-nav mobile-nav me-auto">
                        <li class="nav-item">
                                    <a class="nav-link" asp-controller="TrangChu" asp-action="Index">Tổng quan</a>
                        </li>
                        <li class="nav-item">
                                    <a class="nav-link" asp-controller="NhanVats" asp-action="Index">Nhân vật</a>
                        </li>
                        <li class="nav-item">
                                    <a class="nav-link" asp-controller="MauNhanVats" asp-action="Index">Mẫu nhân vật</a>
                        </li>
                        <li class="nav-item">
                                    <a class="nav-link" asp-controller="TaiNguyens" asp-action="Index">Thư viện 3D</a>
                        </li>
                        <li class="nav-item">
                                    <a class="nav-link" asp-controller="AnhTaiLens" asp-action="Index">Ảnh tải lên</a>
                                </li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" asp-controller="QuanTri" asp-action="Dashboard">Quản trị</a>
                                    </li>
                                }
                    </ul>
                            <div class="topbar-actions">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <span class="user-chip">@User.Identity.Name</span>
                                    <a class="btn btn-light btn-sm" asp-controller="TaiNguyens" asp-action="Index">Thư viện</a>
                                    <a class="btn btn-primary btn-sm" asp-controller="NhanVats" asp-action="Create">Tạo nhân vật</a>
                                    <form asp-controller="TaiKhoan" asp-action="DangXuat" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-outline-secondary btn-sm" type="submit">Đăng xuất</button>
                                    </form>
                                }
                                else
                                {
                                    <a class="btn btn-light btn-sm" asp-controller="TaiKhoan" asp-action="DangKy">Đăng ký</a>
                                    <a class="btn btn-primary btn-sm" asp-controller="TaiKhoan" asp-action="DangNhap">Đăng nhập</a>
                                }
                            </div>
                        </div>
                </div>
            </nav>
        </header>

            <main role="main" class="content-area">
                @RenderBody()
            </main>

            <footer class="app-footer">
                <span>&copy; 2026 Dựng Mô Hình Studio</span>
                <a asp-controller="TrangChu" asp-action="Privacy">Chính sách</a>
            </footer>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
