<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DungMoHinh</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DungMoHinh.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="TrangChu" asp-action="Index">DungMoHinh</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Mo dieu huong">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="NhanVats" asp-action="Index">Nhan vat</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="MauNhanVats" asp-action="Index">Mau nhan vat</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="TaiNguyens" asp-action="Index">Tai nguyen</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="AnhTaiLens" asp-action="Index">Anh tai len</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="QuanTri" asp-action="Dashboard">Quan tri</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - DungMoHinh - <a asp-controller="TrangChu" asp-action="Privacy">Chinh sach</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
